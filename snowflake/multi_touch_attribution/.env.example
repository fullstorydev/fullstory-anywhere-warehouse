# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Snowflake connection ──────────────────────────────────────────────────────
# Name of the connection profile in ~/.snowsql/config or ~/.snowflake/config.toml
SNOWSQL_CONN=fs_marketing_attr
SNOWFLAKE_ROLE=SYSADMIN  # Role with CREATE DATABASE privilege; leave blank to use connection default

# Warehouse used for Dynamic Table refresh (Phases 2 & 3)
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ── FullStory source tables ───────────────────────────────────────────────────
# These are the raw FullStory Data Destination table names in your Snowflake account.
# Find them in your FullStory workspace under Integrations > Data Destinations.
FS_DATABASE=FULLSTORY_PROD
FS_SCHEMA=FS_DATA_DESTINATIONS
FS_EVENTS_TABLE=ACME_abc123_EVENTS
FS_SOURCE_PROPS_TABLE=ACME_abc123_SOURCE_PROPERTIES
FS_USERS_TABLE=ACME_abc123_USERS
FS_CUSTOM_EVENTS_TABLE=ACME_abc123_CUSTOM_EVENTS
